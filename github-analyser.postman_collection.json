{
  "info": {
    "name": "GitHub Analyser API",
    "description": "Postman collection for the GitHub Analyser REST API. Deployed on Render.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "github-analyser-collection-v2"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://github-analyser-amqq.onrender.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Analyse",
      "description": "Run these first to populate the database before using any other routes.",
      "item": [
        {
          "name": "Analyse torvalds",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/profiles/analyze/torvalds",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "analyze", "torvalds"]
            },
            "description": "Fetches, computes and stores the GitHub profile for torvalds. Run this before any get/compare requests."
          },
          "response": []
        },
        {
          "name": "Analyse gaearon",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/profiles/analyze/gaearon",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "analyze", "gaearon"]
            },
            "description": "Fetches, computes and stores the GitHub profile for gaearon (Dan Abramov). Run this before any get/compare requests."
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Profiles",
      "description": "Read and delete stored profiles.",
      "item": [
        {
          "name": "Get All Profiles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/profiles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles"]
            },
            "description": "Returns all analysed profiles stored in the database."
          },
          "response": []
        },
        {
          "name": "Get Single Profile — torvalds",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/profiles/torvalds",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "torvalds"]
            },
            "description": "Fetches the cached profile for torvalds."
          },
          "response": []
        },
        {
          "name": "Get Single Profile — gaearon",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/profiles/gaearon",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "gaearon"]
            },
            "description": "Fetches the cached profile for gaearon."
          },
          "response": []
        },
        {
          "name": "Delete Profile — torvalds",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/profiles/torvalds",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "torvalds"]
            },
            "description": "Deletes torvalds from the database."
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Compare",
      "description": "Compare two analysed profiles side by side.",
      "item": [
        {
          "name": "Compare torvalds vs gaearon",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/profiles/compare?users=torvalds,gaearon",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profiles", "compare"],
              "query": [
                {
                  "key": "users",
                  "value": "torvalds,gaearon",
                  "description": "Comma-separated usernames. Both must be analysed first."
                }
              ]
            },
            "description": "Compares torvalds and gaearon side by side. Both must be analysed first."
          },
          "response": []
        }
      ]
    }
  ]
}
